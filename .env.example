# ProjectZ — Environment Variables
#
# Copy this file to .env and fill in your values.
# docker-compose.yml reads from .env automatically.

# Server port
PORT=8080

# Path to markdown content directory
CONTENT_PATH=/app/content

# Google Sheets integration (optional)
# Create a service account at https://console.cloud.google.com/
# and share your spreadsheet with the service account email.
GOOGLE_SHEETS_KEY=
GOOGLE_SHEET_ID=

# Cloudflare Tunnel token (if using cloudflared)
# Create a tunnel at https://one.dash.cloudflare.com/
CF_TUNNEL_TOKEN=
